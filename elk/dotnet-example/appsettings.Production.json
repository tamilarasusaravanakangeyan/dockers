{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "dotnet-api",
    "Environment": "production",
    "Endpoint": "http://apm-server:8200",
    "Protocol": "HttpProtobuf",
    "Traces": {
      "Enabled": true,
      "SamplingRate": 0.1
    },
    "Metrics": {
      "Enabled": true,
      "IntervalMilliseconds": 60000
    },
    "Logs": {
      "Enabled": true,
      "IncludeFormattedMessage": true,
      "IncludeScopes": false
    }
  }
}
