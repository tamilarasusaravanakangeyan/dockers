{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "OpenTelemetry": "Debug"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "dotnet-api",
    "Environment": "development",
    "Endpoint": "http://localhost:4320",
    "Protocol": "HttpProtobuf",
    "Traces": {
      "Enabled": true,
      "SamplingRate": 1.0
    },
    "Metrics": {
      "Enabled": true,
      "IntervalMilliseconds": 60000
    },
    "Logs": {
      "Enabled": true,
      "IncludeFormattedMessage": true,
      "IncludeScopes": true
    }
  }
}
